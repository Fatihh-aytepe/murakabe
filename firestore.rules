rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuth() &&
        get(/databases/$(database)/documents/roles/owner).data.get('uid', '') == request.auth.uid;
    }

    function isAdmin() {
      return isAuth() && (
        isOwner() ||
        (exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isCommunityAdmin(communityId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/communities/$(communityId)) &&
        get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid == request.auth.uid;
    }

    function isMember(communityId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
    }

    // ── Kullanıcı dokümanları ──────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if isAuth() && request.auth.uid == userId;

      match /{sub}/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
        allow read: if isOwner();
      }
    }

    // ── Roller ────────────────────────────────────────────────────────────
    match /roles/owner {
      allow read: if isAuth();
      // Sadece yetkili e-posta ilk kez oluşturabilir; sonrasında yalnızca mevcut owner güncelleyebilir
      allow create: if isAuth()
        && !exists(/databases/$(database)/documents/roles/owner)
        && request.auth.token.email == 'yavuzbera02@gmail.com';
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /roles/{docId} {
      allow read: if isAuth();
      // owner belgesi buradaki genel write kuralı kapsamı dışında; sadece /roles/owner kuralları geçerli
      allow write: if isOwner() && docId != 'owner';
    }

    // ── Admin/Sahip Başvuruları ──────────────────────────────────────────────
    match /adminRequests/{requestId} {
      allow create: if isAuth()
        && requestId == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow get: if isAuth() && (isOwner() || request.auth.uid == requestId);
      allow list: if isAdmin();
      allow update, delete: if isOwner();
    }

    // ── Bildirimler ───────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow create: if isAdmin();
      allow read, list: if isAuth() && (
        isOwner() ||
        isAdmin() ||
        resource.data.targetUid == request.auth.uid
      );
      // Hedef kullanıcı yalnızca okundu bilgisini (read) güncelleyebilir
      allow update: if isAuth() && (
        isOwner() ||
        isAdmin() ||
        (resource.data.targetUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']))
      );
      allow delete: if isOwner() || isAdmin() || resource.data.targetUid == request.auth.uid;
    }

    // ── Davet kodu arama tablosu ─────────────────────────────────────────────
    // inviteCode → communityId eşleşmesi; kodu bilen get yapabilir, list sadece admin.
    // inviteCode artık topluluk belgesinde değil, burada tutulur.
    match /inviteLookup/{code} {
      allow get: if isAuth();
      allow list: if isAdmin();
      allow create, update: if isAdmin();
      // Topluluk yöneticisi kendi topluluğunun kodunu yenileyebilir (eski kodu siler)
      allow delete: if isOwner() ||
        (isAuth() &&
         resource.data.communityId is string &&
         get(/databases/$(database)/documents/communities/$(resource.data.communityId)).data.adminUid == request.auth.uid);
    }

    // ── Topluluklar ────────────────────────────────────────────────────────
    match /communities/{communityId} {
      // get: topluluk önizlemesi için açık (inviteCode artık burada yok)
      // list: yalnızca admin tüm toplulukları listeleyebilir
      allow get: if isAuth();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isOwner() || isCommunityAdmin(communityId);
      allow update: if isOwner() || isCommunityAdmin(communityId) ||
        // Katılım batch'i: herhangi bir auth kullanıcı yalnızca memberCount'u tam 1 artırabilir
        (isAuth() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount']) &&
         request.resource.data.memberCount == resource.data.memberCount + 1);

      // Özel topluluk ayarları (inviteCode vb.) — owner ve topluluk yöneticisi erişebilir
      match /private/{docId} {
        allow read: if isOwner() || isCommunityAdmin(communityId);
        allow create, update: if isOwner() || isCommunityAdmin(communityId);
        allow delete: if isOwner() || isCommunityAdmin(communityId);
      }

      match /members/{userId} {
        // Üye listesi: yalnızca üyeler, adminler veya kullanıcının kendisi görebilir
        // resource.data.uid eklendi: collectionGroup sorgularında uid field'ı query-provable
        allow read: if isAdmin() || isMember(communityId) || request.auth.uid == userId || resource.data.uid == request.auth.uid;
        allow create: if isAuth() && request.auth.uid == userId && request.resource.data.uid == request.auth.uid && (
          // Topluluk kurucusu (adminUid) kendi 'admin' rolündeki kaydını açar
          (isAdmin()
           && get(/databases/$(database)/documents/communities/$(communityId)).data.adminUid == request.auth.uid
           && request.resource.data.role == 'admin'
           && request.resource.data.keys().hasOnly(['uid', 'role', 'joinedAt']))
          ||
          // Davet koduyla katılım: inviteLookup'ta kodu ve topluluk eşleşmesini doğrula
          (request.resource.data.role == 'member'
           && request.resource.data.keys().hasOnly(['uid', 'role', 'joinedAt', 'inviteCode'])
           && exists(/databases/$(database)/documents/inviteLookup/$(request.resource.data.inviteCode))
           && get(/databases/$(database)/documents/inviteLookup/$(request.resource.data.inviteCode)).data.communityId == communityId)
        );
        allow update, delete: if isOwner() || isCommunityAdmin(communityId);
      }

      match /messages/{messageId} {
        allow read: if isMember(communityId);
        allow create: if isMember(communityId) && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if isOwner() || isCommunityAdmin(communityId);
      }

      match /announcements/{announcementId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || isCommunityAdmin(communityId);
      }

      match /tasks/{taskId} {
        allow read: if isMember(communityId);
        allow create, delete: if isOwner() || isCommunityAdmin(communityId);
        // Owner/admin her şeyi güncelleyebilir; üye sadece completions.{kendi_uid} alanını yazabilir
        allow update: if isOwner() || isCommunityAdmin(communityId) ||
          (isMember(communityId) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completions']) &&
           request.resource.data.completions.diff(resource.data.completions).affectedKeys().hasOnly([request.auth.uid]));
      }
    }
  }
}
