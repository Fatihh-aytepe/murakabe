rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı fonksiyonlar ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuth() && (
        request.auth.token.email == 'aytepe0203@gmail.com' ||
        (exists(/databases/$(database)/documents/roles/owner) &&
         get(/databases/$(database)/documents/roles/owner).data.uid == request.auth.uid)
      );
    }

    function isAdmin() {
      return isAuth() && (
        isOwner() ||
        (exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isMember(communityId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
    }

    // ── Kullanıcı dokümanları ──────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if isAuth() && request.auth.uid == userId;

      match /{sub}/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Roller ────────────────────────────────────────────────────────────
    // roles/owner: ilk kurulumda (doküman yokken) oluşturmaya izin ver;
    // sonrasında sadece mevcut sahip değiştirebilir.
    match /roles/owner {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isOwner();
    }
    match /roles/{docId} {
      allow read: if isAuth();
      allow write: if isOwner();
    }

    // ── Admin başvuruları ─────────────────────────────────────────────────
    match /adminRequests/{userId} {
      allow get, write: if isAuth() && request.auth.uid == userId;
      allow list, update: if isOwner();
    }

    // ── Bildirimler ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow create: if isAuth();
      allow read, update: if isAuth() && (
        isOwner() ||
        isAdmin() ||
        resource.data.targetUid == request.auth.uid
      );
    }

    // ── Topluluklar ────────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();

      // Üyeler
      match /members/{userId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == userId;
        allow update, delete: if isAdmin() || isOwner();
      }

      // Mesajlar
      match /messages/{messageId} {
        allow read: if isMember(communityId);
        allow create: if isMember(communityId) &&
                         request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if isAdmin();
      }

      // Duyurular
      match /announcements/{announcementId} {
        allow read: if isMember(communityId);
        allow write: if isAdmin();
      }

      // Görevler — üyeler "Tamamladım" için update yapabilir
      match /tasks/{taskId} {
        allow read: if isMember(communityId);
        allow create, delete: if isAdmin();
        allow update: if isAdmin() || isMember(communityId);
      }
    }
  }
}
